# URL del Web App de Google Apps Script
# Obtener en: Script > Implementar > 
# Nueva implementación > Aplicación web
# Acceso: Cualquier persona (anónimo)
VITE_SHEETS_API_URL=https://script.google.com/macros/s/XXXX/exec

# ID del atleta actual
VITE_ATLETA_ID=v-atleta-1

# Usar datos mock (true) o Sheets real (false)
# Cambiar a false cuando SHEETS_API_URL esté configurada
VITE_USE_MOCK=true
